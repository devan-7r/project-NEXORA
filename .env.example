# FraudShield AI - Supabase Environment Variables
# Copy this file to .env.local and fill in your Supabase project details.
# IMPORTANT: Never commit .env.local to git.

# Found in: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Found in: Supabase Dashboard → Project Settings → API → anon / public key
# NEVER use the service_role key on the frontend!
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
